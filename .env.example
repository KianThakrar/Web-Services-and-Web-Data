# Database (docker-compose service name is "db", not localhost)
DATABASE_URL=postgresql://f1_app:postgres@db:5432/f1_racing_db

# PostgreSQL container credentials (used by docker-compose to initialise the db container)
POSTGRES_USER=f1_app
POSTGRES_PASSWORD=postgres
POSTGRES_DB=f1_racing_db

# Authentication
# SECURITY: Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Zero-downtime key rotation: set SECRET_KEY_PREVIOUS to the old key before rotating SECRET_KEY.
# Once all tokens issued with the old key have expired, clear this value.
SECRET_KEY_PREVIOUS=

# AI Integration (optional — cached summaries work without this)
ANTHROPIC_API_KEY=

# Application
APP_NAME=F1 Racing Intelligence API
DEBUG=false

# CORS — comma-separated list of allowed origins (no wildcards)
# For local development: http://localhost:3000,http://localhost:8000
# For production: set to your actual frontend domain(s)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# MCP SSE transport
# Leave blank to allow local-only SSE without an API key.
# Required if you bind SSE beyond localhost.
MCP_API_KEY=
MCP_SSE_HOST=127.0.0.1
MCP_SSE_PORT=3001
